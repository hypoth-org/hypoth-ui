{
  "name": "@hypoth-ui/react",
  "version": "0.1.2",
  "type": "module",
  "description": "React adapter components for the hypoth-ui design system (Alpha)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hypoth-ui/hypoth-ui.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/hypoth-ui/hypoth-ui#readme",
  "keywords": [
    "react",
    "design-system",
    "components",
    "web-components",
    "hypoth-ui"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/client.ts --format esm --dts --external react --external @hypoth-ui/primitives-dom",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:a11y": "vitest run --config vitest.a11y.config.ts"
  },
  "dependencies": {
    "@hypoth-ui/primitives-dom": "workspace:*"
  },
  "peerDependencies": {
    "@hypoth-ui/wc": ">=0.1.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@hypoth-ui/test-utils": "workspace:*",
    "@hypoth-ui/tokens": "workspace:*",
    "@hypoth-ui/wc": "workspace:*",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "happy-dom": "^13.10.0",
    "jest-axe": "^8.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
