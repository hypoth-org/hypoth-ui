{
  "name": "@hypoth-ui/wc",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "description": "Web Components (Lit) for the hypoth-ui design system (Alpha)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hypoth-ui/hypoth-ui.git",
    "directory": "packages/wc"
  },
  "homepage": "https://github.com/hypoth-ui/hypoth-ui#readme",
  "keywords": [
    "web-components",
    "lit",
    "design-system",
    "custom-elements",
    "hypoth-ui"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./primitives": {
      "types": "./dist/primitives.d.ts",
      "import": "./dist/primitives.js"
    },
    "./form-controls": {
      "types": "./dist/form-controls.d.ts",
      "import": "./dist/form-controls.js"
    },
    "./overlays": {
      "types": "./dist/overlays.d.ts",
      "import": "./dist/overlays.js"
    },
    "./navigation": {
      "types": "./dist/navigation.d.ts",
      "import": "./dist/navigation.js"
    },
    "./data-display": {
      "types": "./dist/data-display.d.ts",
      "import": "./dist/data-display.js"
    },
    "./feedback": {
      "types": "./dist/feedback.d.ts",
      "import": "./dist/feedback.js"
    },
    "./layout": {
      "types": "./dist/layout.d.ts",
      "import": "./dist/layout.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:a11y": "vitest run --config vitest.a11y.config.ts"
  },
  "dependencies": {
    "@date-fns/tz": "^1.2.0",
    "@hypoth-ui/primitives-dom": "workspace:*",
    "date-fns": "^4.1.0",
    "lit": "^3.1.0",
    "lucide": "^0.468.0"
  },
  "peerDependencies": {
    "@hypoth-ui/css": ">=0.1.0",
    "@hypoth-ui/tokens": ">=0.1.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.8.0",
    "@hypoth-ui/test-utils": "workspace:*",
    "happy-dom": "^13.10.0",
    "jest-axe": "^8.0.0",
    "playwright-core": "^1.40.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
