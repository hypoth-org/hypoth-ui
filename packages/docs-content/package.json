{
  "name": "@hypoth-ui/docs-content",
  "version": "0.1.2",
  "type": "module",
  "description": "Documentation content packs for the hypoth-ui design system (Alpha)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hypoth-ui/hypoth-ui.git",
    "directory": "packages/docs-content"
  },
  "homepage": "https://github.com/hypoth-ui/hypoth-ui#readme",
  "keywords": [
    "documentation",
    "content",
    "design-system",
    "mdx",
    "hypoth-ui"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifests/*": "./manifests/*.json",
    "./components/*": "./components/*.mdx",
    "./guides/*": "./guides/*.mdx",
    "./editions/*": "./editions/*.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "manifests",
    "components",
    "guides",
    "editions"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hypoth-ui/docs-core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
