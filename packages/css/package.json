{
  "name": "@hypoth-ui/css",
  "version": "0.1.0",
  "type": "module",
  "description": "CSS layers and base styles for the hypoth-ui design system (Alpha)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hypoth-ui/hypoth-ui.git",
    "directory": "packages/css"
  },
  "homepage": "https://github.com/hypoth-ui/hypoth-ui#readme",
  "keywords": [
    "css",
    "css-layers",
    "design-system",
    "styles",
    "hypoth-ui"
  ],
  "exports": {
    ".": "./dist/index.css",
    "./layers/reset": "./src/layers/reset.css",
    "./layers/tokens": "./src/layers/tokens.css",
    "./layers/base": "./src/layers/base.css",
    "./layers/components": "./src/layers/components.css",
    "./layers/utilities": "./src/layers/utilities.css",
    "./layers/overrides": "./src/layers/overrides.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/layers"
  ],
  "dependencies": {
    "@hypoth-ui/tokens": "workspace:*",
    "@hypoth-ui/wc": "workspace:*"
  },
  "scripts": {
    "build": "postcss src/index.css -o dist/index.css",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:unit": "vitest run"
  },
  "devDependencies": {
    "postcss": "^8.4.0",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.0.0",
    "cssnano": "^6.0.0",
    "vitest": "^1.0.0"
  }
}
