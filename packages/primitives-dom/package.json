{
  "name": "@hypoth-ui/primitives-dom",
  "version": "0.0.0",
  "type": "module",
  "description": "DOM behavior primitives for the hypoth-ui design system — focus trap, roving focus, type-ahead (Alpha)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hypoth-ui/hypoth-ui.git",
    "directory": "packages/primitives-dom"
  },
  "homepage": "https://github.com/hypoth-ui/hypoth-ui#readme",
  "keywords": ["primitives", "dom", "focus-trap", "accessibility", "hypoth-ui"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:a11y": "vitest run --config vitest.a11y.config.ts"
  },
  "devDependencies": {
    "happy-dom": "^13.10.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
