{
  "name": "@hypoth-ui/tokens",
  "version": "1.0.1",
  "type": "module",
  "description": "Design tokens for the hypoth-ui design system — CSS custom properties, TypeScript constants",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hypoth-ui/hypoth-ui.git",
    "directory": "packages/tokens"
  },
  "homepage": "https://github.com/hypoth-ui/hypoth-ui#readme",
  "keywords": [
    "design-tokens",
    "css-variables",
    "theming",
    "design-system",
    "hypoth-ui"
  ],
  "exports": {
    ".": {
      "types": "./dist/ts/index.d.ts",
      "import": "./dist/ts/index.js"
    },
    "./css": "./dist/css/tokens.css",
    "./json": "./dist/json/tokens.json",
    "./runtime": {
      "types": "./dist/ts/runtime/index.d.ts",
      "import": "./dist/ts/runtime/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsx src/build/build.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
