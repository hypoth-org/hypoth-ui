{
  "$description": "HoverCard component tokens — references overlay type tokens",
  "hover-card": {
    "content": {
      "bg": { "$value": "{overlay.bg}", "$type": "color" },
      "border-color": { "$value": "{overlay.border-color}", "$type": "color" },
      "border-radius": { "$value": "0.375rem", "$type": "dimension" },
      "shadow": { "$value": "{overlay.shadow}", "$type": "shadow" },
      "padding": { "$value": "1rem", "$type": "dimension" },
      "min-width": { "$value": "16rem", "$type": "dimension" },
      "max-width": { "$value": "20rem", "$type": "dimension" }
    },
    "z-index": { "$value": "900", "$type": "number" }
  }
}
