{
  "$description": "Avatar component tokens — image and fallback styling",
  "avatar": {
    "size-sm": { "$value": "2rem", "$type": "dimension" },
    "size-md": { "$value": "2.5rem", "$type": "dimension" },
    "size-lg": { "$value": "3rem", "$type": "dimension" },
    "size-xl": { "$value": "4rem", "$type": "dimension" },
    "border-radius": { "$value": "9999px", "$type": "dimension" },
    "image": {
      "object-fit": { "$value": "cover", "$type": "string" }
    },
    "fallback": {
      "bg": { "$value": "{color.background.muted}", "$type": "color" },
      "color": { "$value": "{color.foreground.muted}", "$type": "color" },
      "font-size-sm": { "$value": "0.75rem", "$type": "dimension" },
      "font-size-md": { "$value": "0.875rem", "$type": "dimension" },
      "font-size-lg": { "$value": "1rem", "$type": "dimension" },
      "font-size-xl": { "$value": "1.25rem", "$type": "dimension" },
      "font-weight": { "$value": "500", "$type": "fontWeight" }
    },
    "group": {
      "overlap": { "$value": "-0.5rem", "$type": "dimension" },
      "border-color": { "$value": "{color.background.default}", "$type": "color" },
      "border-width": { "$value": "2px", "$type": "dimension" }
    }
  }
}
