{
  "$description": "Accordion component tokens — references container type tokens",
  "accordion": {
    "border-color": { "$value": "{container.border-color}", "$type": "color" },
    "border-radius": { "$value": "{container.border-radius}", "$type": "dimension" },
    "item": {
      "border-color": { "$value": "{container.border-color}", "$type": "color" }
    },
    "trigger": {
      "padding": { "$value": "1rem", "$type": "dimension" },
      "font-size": { "$value": "0.875rem", "$type": "dimension" },
      "font-weight": { "$value": "500", "$type": "fontWeight" },
      "bg": { "$value": "transparent", "$type": "color" },
      "bg-hover": { "$value": "{color.background.subtle}", "$type": "color" },
      "focus-ring": { "$value": "{color.primary.default}", "$type": "color" }
    },
    "content": {
      "padding": { "$value": "1rem", "$type": "dimension" }
    },
    "animation-duration": { "$value": "200ms", "$type": "duration" }
  }
}
