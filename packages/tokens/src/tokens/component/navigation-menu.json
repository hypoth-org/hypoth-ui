{
  "$description": "NavigationMenu component tokens — references navigation type tokens",
  "navigation-menu": {
    "list": {
      "gap": { "$value": "0.25rem", "$type": "dimension" }
    },
    "item": {
      "font-size": { "$value": "0.875rem", "$type": "dimension" }
    },
    "trigger": {
      "padding-x": { "$value": "{nav.item.padding-x}", "$type": "dimension" },
      "padding-y": { "$value": "{nav.item.padding-y}", "$type": "dimension" },
      "font-weight": { "$value": "500", "$type": "fontWeight" },
      "color": { "$value": "{nav.item.color-active}", "$type": "color" },
      "bg-hover": { "$value": "{nav.item.bg-hover}", "$type": "color" },
      "border-radius": { "$value": "0.25rem", "$type": "dimension" }
    },
    "content": {
      "padding": { "$value": "1rem", "$type": "dimension" },
      "gap": { "$value": "0.5rem", "$type": "dimension" },
      "min-width": { "$value": "12rem", "$type": "dimension" }
    },
    "viewport": {
      "bg": { "$value": "{overlay.bg}", "$type": "color" },
      "border-color": { "$value": "{color.border.default}", "$type": "color" },
      "border-radius": { "$value": "0.375rem", "$type": "dimension" },
      "shadow": { "$value": "{overlay.shadow}", "$type": "shadow" },
      "margin-top": { "$value": "0.5rem", "$type": "dimension" }
    },
    "link": {
      "padding-x": { "$value": "{nav.item.padding-x}", "$type": "dimension" },
      "padding-y": { "$value": "{nav.item.padding-y}", "$type": "dimension" },
      "color": { "$value": "{nav.item.color-active}", "$type": "color" },
      "color-active": { "$value": "{color.primary.default}", "$type": "color" },
      "bg-hover": { "$value": "{nav.item.bg-hover}", "$type": "color" },
      "border-radius": { "$value": "0.25rem", "$type": "dimension" }
    },
    "indicator": {
      "height": { "$value": "2px", "$type": "dimension" },
      "color": { "$value": "{nav.indicator-color}", "$type": "color" }
    }
  }
}
