{
  "$description": "Badge component tokens — references feedback type tokens with per-variant colors",
  "badge": {
    "bg": { "$value": "{color.background.subtle}", "$type": "color" },
    "color": { "$value": "{color.foreground.default}", "$type": "color" },
    "border-radius": { "$value": "9999px", "$type": "dimension" },
    "padding-x": { "$value": "0.625rem", "$type": "dimension" },
    "padding-y": { "$value": "0.125rem", "$type": "dimension" },
    "font-size": { "$value": "0.75rem", "$type": "dimension" },
    "font-weight": { "$value": "500", "$type": "fontWeight" },
    "line-height": { "$value": "1.5", "$type": "number" },
    "primary": {
      "bg": { "$value": "{color.primary.subtle}", "$type": "color" },
      "color": { "$value": "{color.primary.default}", "$type": "color" }
    },
    "success": {
      "bg": { "$value": "{feedback.success.bg}", "$type": "color" },
      "color": { "$value": "{feedback.success.color}", "$type": "color" }
    },
    "warning": {
      "bg": { "$value": "{feedback.warning.bg}", "$type": "color" },
      "color": { "$value": "{feedback.warning.color}", "$type": "color" }
    },
    "error": {
      "bg": { "$value": "{feedback.error.bg}", "$type": "color" },
      "color": { "$value": "{feedback.error.color}", "$type": "color" }
    },
    "info": {
      "bg": { "$value": "{feedback.info.bg}", "$type": "color" },
      "color": { "$value": "{feedback.info.color}", "$type": "color" }
    }
  }
}
