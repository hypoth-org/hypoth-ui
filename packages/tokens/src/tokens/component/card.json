{
  "$description": "Card component tokens — references container type tokens",
  "card": {
    "bg": { "$value": "{container.bg}", "$type": "color" },
    "border-color": { "$value": "{container.border-color}", "$type": "color" },
    "border-radius": { "$value": "{container.border-radius}", "$type": "dimension" },
    "shadow": { "$value": "{container.shadow}", "$type": "shadow" },
    "padding": { "$value": "{container.padding}", "$type": "dimension" },
    "header": {
      "padding": { "$value": "1.5rem 1.5rem 0", "$type": "dimension" },
      "gap": { "$value": "0.375rem", "$type": "dimension" }
    },
    "content": {
      "padding": { "$value": "{container.padding}", "$type": "dimension" }
    },
    "footer": {
      "padding": { "$value": "0 1.5rem 1.5rem", "$type": "dimension" },
      "gap": { "$value": "0.5rem", "$type": "dimension" }
    }
  }
}
