{
  "$description": "Drawer component tokens — mobile-optimized overlay panel",
  "drawer": {
    "overlay": {
      "color": { "$value": "{overlay.backdrop-color}", "$type": "color" }
    },
    "content": {
      "bg": { "$value": "{overlay.bg}", "$type": "color" },
      "shadow": { "$value": "{overlay.shadow}", "$type": "shadow" },
      "padding": { "$value": "1rem", "$type": "dimension" },
      "border-radius": { "$value": "0.75rem", "$type": "dimension" }
    },
    "handle": {
      "width": { "$value": "48px", "$type": "dimension" },
      "height": { "$value": "4px", "$type": "dimension" },
      "bg": { "$value": "{color.border.default}", "$type": "color" },
      "border-radius": { "$value": "9999px", "$type": "dimension" }
    },
    "header": {
      "padding": { "$value": "1rem", "$type": "dimension" },
      "gap": { "$value": "0.25rem", "$type": "dimension" }
    },
    "footer": {
      "padding": { "$value": "1rem", "$type": "dimension" },
      "gap": { "$value": "0.5rem", "$type": "dimension" }
    },
    "title": {
      "font-size": { "$value": "1.125rem", "$type": "dimension" },
      "font-weight": { "$value": "600", "$type": "fontWeight" },
      "color": { "$value": "{color.foreground.default}", "$type": "color" }
    },
    "description": {
      "font-size": { "$value": "0.875rem", "$type": "dimension" },
      "color": { "$value": "{color.foreground.muted}", "$type": "color" }
    },
    "z-index": { "$value": "{overlay.z-index}", "$type": "number" }
  }
}
