{
  "$description": "Table component tokens — references container type tokens",
  "table": {
    "bg": { "$value": "{container.bg}", "$type": "color" },
    "border-color": { "$value": "{container.border-color}", "$type": "color" },
    "border-radius": { "$value": "{container.border-radius}", "$type": "dimension" },
    "header": {
      "bg": { "$value": "{color.background.subtle}", "$type": "color" },
      "color": { "$value": "{color.foreground.muted}", "$type": "color" },
      "font-size": { "$value": "0.75rem", "$type": "dimension" },
      "font-weight": { "$value": "600", "$type": "fontWeight" },
      "padding": { "$value": "0.75rem 1rem", "$type": "dimension" }
    },
    "row": {
      "border-color": { "$value": "{container.border-color}", "$type": "color" },
      "bg-hover": { "$value": "{color.background.subtle}", "$type": "color" },
      "bg-striped": { "$value": "{color.background.muted}", "$type": "color" }
    },
    "cell": {
      "padding": { "$value": "0.75rem 1rem", "$type": "dimension" },
      "font-size": { "$value": "0.875rem", "$type": "dimension" },
      "color": { "$value": "{color.foreground.default}", "$type": "color" }
    }
  }
}
