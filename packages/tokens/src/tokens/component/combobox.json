{
  "$description": "Combobox component tokens — references form-controls type tokens",
  "combobox": {
    "input": {
      "bg": { "$value": "{form-control.bg}", "$type": "color", "$description": "Combobox input background" },
      "border-color": { "$value": "{form-control.border-color}", "$type": "color", "$description": "Combobox input border color" },
      "border-color-hover": { "$value": "{form-control.border-color-hover}", "$type": "color", "$description": "Combobox input border color on hover" },
      "border-color-focus": { "$value": "{form-control.border-color-focus}", "$type": "color", "$description": "Combobox input border color on focus" },
      "border-radius": { "$value": "{form-control.border-radius}", "$type": "dimension", "$description": "Combobox input border radius" },
      "font-size": { "$value": "{form-control.font-size.md}", "$type": "dimension", "$description": "Combobox input font size" },
      "color": { "$value": "{color.foreground.default}", "$type": "color", "$description": "Combobox input text color" },
      "placeholder-color": { "$value": "{form-control.placeholder-color}", "$type": "color", "$description": "Combobox input placeholder color" },
      "min-height": { "$value": "{form-control.height.lg}", "$type": "dimension", "$description": "Combobox input minimum height" },
      "padding-x": { "$value": "{form-control.padding-x.md}", "$type": "dimension", "$description": "Combobox input horizontal padding" },
      "padding-y": { "$value": "{form-control.padding-y.sm}", "$type": "dimension", "$description": "Combobox input vertical padding" },
      "gap": { "$value": "0.25rem", "$type": "dimension", "$description": "Combobox input gap between tags" }
    },
    "tag": {
      "bg": { "$value": "{color.background.subtle}", "$type": "color", "$description": "Combobox tag background" },
      "color": { "$value": "{color.foreground.default}", "$type": "color", "$description": "Combobox tag text color" },
      "border-radius": { "$value": "{radius.sm}", "$type": "dimension", "$description": "Combobox tag border radius" },
      "font-size": { "$value": "{form-control.font-size.sm}", "$type": "dimension", "$description": "Combobox tag font size" },
      "padding-x": { "$value": "{form-control.padding-x.sm}", "$type": "dimension", "$description": "Combobox tag horizontal padding" },
      "padding-y": { "$value": "{form-control.padding-y.sm}", "$type": "dimension", "$description": "Combobox tag vertical padding" },
      "gap": { "$value": "0.25rem", "$type": "dimension", "$description": "Combobox tag gap between text and remove button" },
      "max-width": { "$value": "10rem", "$type": "dimension", "$description": "Combobox tag max width before truncation" },
      "remove-color": { "$value": "{form-control.placeholder-color}", "$type": "color", "$description": "Combobox tag remove button color" },
      "remove-color-hover": { "$value": "{color.foreground.default}", "$type": "color", "$description": "Combobox tag remove button color on hover" }
    },
    "content": {
      "bg": { "$value": "{form-control.bg}", "$type": "color", "$description": "Combobox dropdown background" },
      "border-color": { "$value": "{form-control.border-color}", "$type": "color", "$description": "Combobox dropdown border color" },
      "border-radius": { "$value": "{form-control.border-radius}", "$type": "dimension", "$description": "Combobox dropdown border radius" },
      "shadow": { "$value": "{shadow.lg}", "$type": "shadow", "$description": "Combobox dropdown shadow" },
      "max-height": { "$value": "15rem", "$type": "dimension", "$description": "Combobox dropdown max height" },
      "z-index": { "$value": "100", "$type": "number", "$description": "Combobox dropdown z-index" }
    },
    "option": {
      "padding-x": { "$value": "{form-control.padding-x.md}", "$type": "dimension", "$description": "Combobox option horizontal padding" },
      "padding-y": { "$value": "{form-control.padding-y.sm}", "$type": "dimension", "$description": "Combobox option vertical padding" },
      "bg-hover": { "$value": "{color.background.subtle}", "$type": "color", "$description": "Combobox option background on hover" },
      "bg-active": { "$value": "{color.primary.subtle}", "$type": "color", "$description": "Combobox option background when selected" },
      "color": { "$value": "{color.foreground.default}", "$type": "color", "$description": "Combobox option text color" },
      "color-active": { "$value": "{color.primary.default}", "$type": "color", "$description": "Combobox option text color when selected" },
      "font-size": { "$value": "{form-control.font-size.md}", "$type": "dimension", "$description": "Combobox option font size" }
    },
    "focus-ring": { "$value": "{form-control.focus-ring}", "$type": "color", "$description": "Combobox focus ring color" },
    "error-border-color": { "$value": "{form-control.error-border-color}", "$type": "color", "$description": "Combobox border color in error state" }
  }
}
