{
  "$description": "Tree component tokens — hierarchical list with indent levels",
  "tree": {
    "item": {
      "padding-x": { "$value": "0.5rem", "$type": "dimension" },
      "padding-y": { "$value": "0.375rem", "$type": "dimension" },
      "indent": { "$value": "1.5rem", "$type": "dimension" },
      "border-radius": { "$value": "{container.border-radius}", "$type": "dimension" },
      "color": { "$value": "{color.foreground.default}", "$type": "color" },
      "bg-hover": { "$value": "{color.background.subtle}", "$type": "color" },
      "bg-active": { "$value": "{color.primary.subtle}", "$type": "color" },
      "color-active": { "$value": "{color.primary.default}", "$type": "color" }
    },
    "icon": {
      "size": { "$value": "1rem", "$type": "dimension" },
      "color": { "$value": "{color.foreground.muted}", "$type": "color" },
      "gap": { "$value": "0.5rem", "$type": "dimension" }
    },
    "connector": {
      "color": { "$value": "{container.border-color}", "$type": "color" },
      "width": { "$value": "1px", "$type": "dimension" }
    }
  }
}
