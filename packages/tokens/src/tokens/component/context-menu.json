{
  "$description": "ContextMenu component tokens — references overlay type tokens",
  "context-menu": {
    "content": {
      "bg": { "$value": "{overlay.bg}", "$type": "color" },
      "border-color": { "$value": "{overlay.border-color}", "$type": "color" },
      "border-radius": { "$value": "0.375rem", "$type": "dimension" },
      "shadow": { "$value": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06)", "$type": "shadow" },
      "padding": { "$value": "0.25rem", "$type": "dimension" },
      "min-width": { "$value": "8rem", "$type": "dimension" }
    },
    "item": {
      "padding": { "$value": "0.5rem 0.75rem", "$type": "dimension" },
      "font-size": { "$value": "0.875rem", "$type": "dimension" },
      "color": { "$value": "{color.foreground.default}", "$type": "color" },
      "bg-hover": { "$value": "{color.background.subtle}", "$type": "color" },
      "border-radius": { "$value": "0.25rem", "$type": "dimension" },
      "destructive-color": { "$value": "{color.destructive.default}", "$type": "color" },
      "destructive-bg-hover": { "$value": "{color.destructive.subtle}", "$type": "color" }
    },
    "separator": {
      "color": { "$value": "{color.border.default}", "$type": "color" },
      "margin": { "$value": "0.25rem", "$type": "dimension" }
    },
    "label": {
      "padding": { "$value": "0.5rem 0.75rem", "$type": "dimension" },
      "font-size": { "$value": "0.75rem", "$type": "dimension" },
      "font-weight": { "$value": "600", "$type": "fontWeight" },
      "color": { "$value": "{color.foreground.muted}", "$type": "color" }
    },
    "z-index": { "$value": "950", "$type": "number" }
  }
}
