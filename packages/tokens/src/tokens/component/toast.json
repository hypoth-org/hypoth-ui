{
  "$description": "Toast component tokens — references feedback type tokens with per-severity variants",
  "toast": {
    "bg": { "$value": "{color.background.default}", "$type": "color" },
    "color": { "$value": "{color.foreground.default}", "$type": "color" },
    "border-color": { "$value": "{color.border.default}", "$type": "color" },
    "border-radius": { "$value": "{feedback.border-radius}", "$type": "dimension" },
    "shadow": { "$value": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06)", "$type": "shadow" },
    "padding": { "$value": "{feedback.padding}", "$type": "dimension" },
    "gap": { "$value": "0.75rem", "$type": "dimension" },
    "max-width": { "$value": "24rem", "$type": "dimension" },
    "title": {
      "font-size": { "$value": "0.875rem", "$type": "dimension" },
      "font-weight": { "$value": "600", "$type": "fontWeight" }
    },
    "description": {
      "font-size": { "$value": "0.875rem", "$type": "dimension" },
      "color": { "$value": "{color.foreground.muted}", "$type": "color" }
    },
    "close": {
      "size": { "$value": "1.25rem", "$type": "dimension" }
    },
    "info": {
      "bg": { "$value": "{feedback.info.bg}", "$type": "color" },
      "color": { "$value": "{feedback.info.color}", "$type": "color" },
      "border-color": { "$value": "{feedback.info.border-color}", "$type": "color" }
    },
    "success": {
      "bg": { "$value": "{feedback.success.bg}", "$type": "color" },
      "color": { "$value": "{feedback.success.color}", "$type": "color" },
      "border-color": { "$value": "{feedback.success.border-color}", "$type": "color" }
    },
    "warning": {
      "bg": { "$value": "{feedback.warning.bg}", "$type": "color" },
      "color": { "$value": "{feedback.warning.color}", "$type": "color" },
      "border-color": { "$value": "{feedback.warning.border-color}", "$type": "color" }
    },
    "error": {
      "bg": { "$value": "{feedback.error.bg}", "$type": "color" },
      "color": { "$value": "{feedback.error.color}", "$type": "color" },
      "border-color": { "$value": "{feedback.error.border-color}", "$type": "color" }
    },
    "z-index": { "$value": "1100", "$type": "number" }
  }
}
