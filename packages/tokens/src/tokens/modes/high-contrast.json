{
  "$schema": "../../schemas/dtcg-token.schema.json",
  "$description": "High contrast mode token overrides — maximum contrast oklch variants",
  "color": {
    "background": {
      "default": { "$value": "oklch(1 0 0)", "$type": "color" },
      "subtle": { "$value": "oklch(1 0 0)", "$type": "color" },
      "muted": { "$value": "oklch(0.95 0 0)", "$type": "color" },
      "emphasis": { "$value": "oklch(0 0 0)", "$type": "color" }
    },
    "foreground": {
      "default": { "$value": "oklch(0 0 0)", "$type": "color" },
      "muted": { "$value": "oklch(0 0 0)", "$type": "color" },
      "subtle": { "$value": "oklch(0.3 0 0)", "$type": "color" },
      "inverted": { "$value": "oklch(1 0 0)", "$type": "color" }
    },
    "border": {
      "default": { "$value": "oklch(0 0 0)", "$type": "color" },
      "muted": { "$value": "oklch(0.3 0 0)", "$type": "color" },
      "emphasis": { "$value": "oklch(0 0 0)", "$type": "color" }
    },
    "primary": {
      "default": { "$value": "oklch(0.40 0.25 250)", "$type": "color" },
      "hover": { "$value": "oklch(0.35 0.25 250)", "$type": "color" },
      "active": { "$value": "oklch(0.30 0.25 250)", "$type": "color" }
    },
    "destructive": {
      "default": { "$value": "oklch(0.40 0.25 35)", "$type": "color" },
      "hover": { "$value": "oklch(0.35 0.25 35)", "$type": "color" },
      "active": { "$value": "oklch(0.30 0.25 35)", "$type": "color" }
    },
    "focus": {
      "ring": { "$value": "oklch(0 0 0)", "$type": "color" }
    }
  }
}
