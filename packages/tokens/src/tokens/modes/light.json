{
  "$schema": "../../schemas/dtcg-token.schema.json",
  "$description": "Light mode token overrides - default mode",
  "color": {
    "background": {
      "default": { "$value": "oklch(1 0 0)", "$type": "color" },
      "subtle": { "$value": "oklch(0.985 0 0)", "$type": "color" },
      "muted": { "$value": "oklch(0.97 0 0)", "$type": "color" },
      "emphasis": { "$value": "oklch(0.205 0 0)", "$type": "color" }
    },
    "foreground": {
      "default": { "$value": "oklch(0.205 0 0)", "$type": "color" },
      "muted": { "$value": "oklch(0.556 0 0)", "$type": "color" },
      "subtle": { "$value": "oklch(0.7 0 0)", "$type": "color" },
      "inverted": { "$value": "oklch(1 0 0)", "$type": "color" }
    },
    "border": {
      "default": { "$value": "oklch(0.922 0 0)", "$type": "color" },
      "muted": { "$value": "oklch(0.97 0 0)", "$type": "color" },
      "emphasis": { "$value": "oklch(0.7 0 0)", "$type": "color" }
    }
  }
}
