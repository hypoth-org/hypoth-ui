{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Required Package Metadata",
  "description": "Schema for required fields in each publishable package.json",
  "type": "object",
  "required": ["name", "version", "license", "description", "repository", "homepage", "keywords", "exports", "files"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^@hypoth-ui/",
      "description": "Must use @hypoth-ui scope"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+",
      "description": "Semver version"
    },
    "license": {
      "type": "string",
      "const": "MIT"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "description": "Package description"
    },
    "repository": {
      "type": "object",
      "required": ["type", "url", "directory"],
      "properties": {
        "type": { "const": "git" },
        "url": { "const": "https://github.com/hypoth-org/hypoth-ui.git" },
        "directory": { "type": "string", "pattern": "^packages/" }
      }
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "keywords": {
      "type": "array",
      "minItems": 2,
      "items": { "type": "string" }
    },
    "exports": {
      "type": "object",
      "minProperties": 1
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  }
}
